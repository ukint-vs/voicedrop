---
interface Props {
  animated?: boolean;
  size?: number;
  label?: string;
  className?: string;
  muted?: boolean;
}

const {
  animated = false,
  size = 24,
  label = "VoiceDrop",
  className,
  muted = false,
} = Astro.props;

const classes = ["logomark"];
if (muted) classes.push("logomark--muted");
if (animated) classes.push("logomark--animated");
if (className) classes.push(className);
---

<span
  class={classes.join(" ")}
  style={`--logomark-size: ${size}px;`}
  aria-label={label}
  role="img"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="8 12 84 84"
    width={size}
    height={size}
    aria-hidden="true"
    focusable="false"
  >
    <path
      d="M 50 14 C 65 30, 80 50, 80 65 A 30 30 0 1 1 20 65 C 20 50, 35 30, 50 14 Z"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linejoin="round"></path>

    {
      animated ? (
        <>
          <path
            class="pulse-baseline"
            d="M 26 62 Q 32 55, 38 62 T 50 62 T 62 62 T 74 62"
            fill="none"
            stroke="#e63946"
            stroke-width="0.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            opacity="0.14"
          />
          <path
            class="pulse-animated"
            d="M 26 62 Q 32 55, 38 62 T 50 62 T 62 62 T 74 62"
            pathLength="100"
            fill="none"
            stroke="#e63946"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-dasharray="28 72"
          />
        </>
      ) : (
        <path
          d="M 26 62 Q 32 55, 38 62 T 50 62 T 62 62 T 74 62"
          fill="none"
          stroke="#e63946"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      )
    }
  </svg>
</span>

<style>
  .logomark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--logomark-size);
    height: var(--logomark-size);
    color: var(--ink);
    flex-shrink: 0;
  }

  .logomark--muted {
    color: var(--ink-muted);
    opacity: 0.7;
  }

  .logomark svg {
    display: block;
  }

  .logomark--animated .pulse-animated {
    animation: logomark-pulse 2.4s linear infinite;
  }

  @keyframes logomark-pulse {
    from {
      stroke-dashoffset: 0;
    }
    to {
      stroke-dashoffset: -100;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logomark--animated .pulse-animated {
      animation: none;
      opacity: 0;
    }
    .logomark--animated .pulse-baseline {
      opacity: 1;
      stroke-width: 1.8;
    }
  }
</style>
