---
import Base from "../layouts/Base.astro";
import Wordmark from "../components/Wordmark.astro";
import Logomark from "../components/Logomark.astro";

const base = import.meta.env.BASE_URL.replace(/\/+$/, "");
const url = (path: string) => `${base}/${path.replace(/^\/+/, "")}`;
---

<Base
  title="VoiceDrop — private voice-to-text for iPhone"
  description="VoiceDrop transcribes voice to text entirely on your iPhone. No audio leaves your device. Currently in closed TestFlight beta."
>
  <Wordmark size="large" link={false} withMark animatedMark />

  <h1>Private voice-to-text for iPhone.</h1>

  <p class="lede">
    Record, transcribe, and insert text anywhere — without your voice ever
    leaving your device.
  </p>

  <p>
    VoiceDrop transcribes speech locally on your iPhone using Apple's Neural
    Engine and the open-source Parakeet model. No cloud, no analytics, no
    account. The keyboard extension inserts the transcript at your cursor in
    any app that accepts text.
  </p>

  <div class="pull-quote-block">
    <Logomark size={40} muted label="" />
    <blockquote class="pull-quote">Your voice never leaves your device.</blockquote>
  </div>

  <ul class="features">
    <li>
      <strong>On-device only</strong>
      <span>
        Audio and transcripts never leave your phone. Only the speech model
        itself is downloaded once from Hugging Face during onboarding.
      </span>
    </li>
    <li>
      <strong>39 languages</strong>
      <span>
        English, Russian, Spanish, German, French, Chinese, Japanese, Arabic,
        Hindi, and thirty more — all offline after the first download.
      </span>
    </li>
    <li>
      <strong>Three ways to dictate</strong>
      <span>
        Open the app and tap the mic, press the Action Button from anywhere, or
        use the VoiceDrop keyboard inside any messaging app.
      </span>
    </li>
    <li>
      <strong>No tracking, no SDKs</strong>
      <span>
        Zero analytics integrations. No third-party data collection. TestFlight
        crash reports go through Apple's own MetricKit and can be opted out at
        the iOS level.
      </span>
    </li>
  </ul>

  <div class="cta-row">
    <a
      class="cta"
      href="mailto:ukint-vs@proton.me?subject=VoiceDrop%20TestFlight%20access"
      >Request TestFlight access</a
    >
    <a class="cta secondary" href={url("privacy/")}>Privacy policy</a>
  </div>

  <p class="beta-notice">
    VoiceDrop is in closed beta. Public App Store launch planned once the
    TestFlight cohort validates the experience.
  </p>
</Base>

<style>
  .pull-quote-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    margin: var(--space-3xl) 0;
  }

  .pull-quote {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(24px, 4.5vw, 34px);
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--ink);
    text-align: center;
    margin: 0;
    padding: 0 var(--space-md);
    border: 0;
  }

  .features {
    padding-left: 0;
    list-style: none;
    margin: var(--space-xl) 0;
  }

  .features li {
    padding: var(--space-sm) 0;
    border-top: 1px solid var(--border);
  }

  .features li:last-child {
    border-bottom: 1px solid var(--border);
  }

  .features li strong {
    font-weight: 600;
    display: block;
    margin-bottom: 2px;
  }

  .features li span {
    color: var(--ink-muted);
    font-size: 15px;
    line-height: 1.5;
  }

  .cta-row {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin: var(--space-2xl) 0 var(--space-lg);
  }

  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: var(--space-sm) 22px;
    background: var(--ink);
    color: var(--bg);
    border: 1px solid var(--ink);
    border-radius: var(--radius-full);
    text-decoration: none;
    font-weight: 500;
    font-size: 15px;
  }

  .cta:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: #ffffff;
  }

  .cta:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .cta:active {
    transform: translateY(1px);
  }

  .cta.secondary {
    background: transparent;
    color: var(--ink);
    border-color: var(--border);
  }

  .cta.secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: transparent;
  }

  .beta-notice {
    color: var(--ink-muted);
    font-size: 15px;
  }
</style>
